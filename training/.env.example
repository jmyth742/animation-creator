# =============================================================================
# RunPod Training Configuration
# Copy this to .env and fill in your values:  cp .env.example .env
# =============================================================================

# RunPod API key — get from https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=

# Pod ID — auto-filled by 'pod.sh create', or set manually
POD_ID=

# GPU type for training
# Options: "NVIDIA RTX A6000" (48GB, ~$0.44/hr — best value)
#          "NVIDIA A100 80GB PCIe" (~$1.19/hr — faster)
#          "NVIDIA A100-SXM4-80GB" (~$1.39/hr — fastest)
GPU_TYPE=NVIDIA RTX A6000

# Network volume ID (optional) — for persistent storage across pod stop/start
# Create one at https://www.runpod.io/console/user/storage
NETWORK_VOLUME_ID=

# Docker image — PyTorch with CUDA
DOCKER_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04
