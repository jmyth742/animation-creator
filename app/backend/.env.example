# Copy this file to .env and fill in the values before starting the server.
# Generate a secret key with: openssl rand -hex 32

SECRET_KEY=replace-this-with-output-of-openssl-rand-hex-32

# Optional overrides (defaults shown):
# DATABASE_URL=sqlite:///./storybuilder.db
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# WORKSPACE_ROOT=/workspace/text-to-video
